@model List<GetActivitiesDto>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Activities List</h2>
           <a href="Activities/Add" class="btn btn-success">
               ➕ Add new activity
           </a>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Start Date</th>
                <th>Duration</th>
                <th>Category</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var activity in Model)
            {
                <tr>
                    <td>@activity.Title</td>
                    <td>@activity.Description</td>
                    <td>@activity.StartDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(activity.Duration.HasValue ? activity.Duration.ToString() : "N/A")</td>
                    <td>@activity.Category</td>
                    <td>@(activity.IsCompleted ? "Completed" : "Pending")</td>
                    <td>
                        @if(activity.UserId == ViewBag.userId)
                        {
                            <a href="/Activities/Details/@activity.Id" class="btn btn-info btn-sm">Details</a>
                            <a href="/Activities/Edit/@activity.Id" class="btn btn-warning btn-sm">Edit</a>
                            if (!activity.IsCompleted)
                            {
                                <a href="https://localhost:7190/Activities/Complete/@activity.Id" class="btn btn-primary btn-sm">Complete</a>
                            }
                        }
                        else
                        {
                            <a href="/Activities/Details/@activity.Id" class="btn btn-info btn-sm">Details</a>
                            <a href="/Activities/Edit/@activity.Id" class="btn btn-warning btn-sm">Leave</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

